# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT="development"
DEBUG=True

# ── Database ──────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/dbname"

# ── Redis (Token Blacklist & Session) ─────────────────────────────────────
# Only required once the frontend starts using token rotation/logout
REDIS_URL="redis://localhost:6379/0"

# ── JWT & Security ────────────────────────────────────────────────────────
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY="your_super_secret_key_here"
CSRF_SECRET_KEY="your_csrf_secret_key_here"
ALGORITHM="HS256"

# ── Google OAuth2 ──────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# ── Email (Password reset & Notifications) ─────────────────────────────────
# SMTP configuration (example for Gmail)
MAIL_USERNAME="your_email@gmail.com"
MAIL_PASSWORD="your_app_password"
MAIL_FROM="your_email@esi-sba.dz"
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
